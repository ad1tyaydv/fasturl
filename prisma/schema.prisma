generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


enum Plan {
  FREE
  ESSENTIAL
  PRO
}

model User {
  id             String      @id @default(uuid())
  email          String      @unique
  password       String
  userName       String?
  ipAddress      String?

  plan           Plan      @default(FREE)
  planStatedAt   DateTime?
  planExpiresAt  DateTime?

  links          Link[]
  qr             Qr[]
  bulkLinks      BulkLinks[]

  createdAt      DateTime    @default(now())
}

model Link {
  id           String      @id @default(uuid())
  linkName     String?
  shorturl     String      @unique
  original     String

  clicks       Int         @default(0)
  clickLogs    Click[]

  bulkLinksId  String?
  bulk         BulkLinks?  @relation(fields: [bulkLinksId], references: [id])

  checkBulk  Boolean     @default(false)

  ipAddress    String?

  password     String?
  expiresAt    DateTime?
  
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime    @default(now())
}

model Click {
  id          String      @id @default(uuid())

  linkId      String
  link        Link        @relation(fields: [linkId], references: [id])

  qrId        String?
  qr          Qr?         @relation(fields: [qrId], references: [id])

  ip          String
  country     String?
  state       String?
  city        String?

  device      String?
  browser     String?
  OS          String?

  referrer    String?

  createdAt   DateTime    @default(now())

  @@index([linkId])
  @@index([qrId])
  @@index([country])
}

model Qr {
  id          String      @id @default(uuid())
  qrName      String?
  shortUrl    String
  longUrl     String

  qrImage     String

  clicks      Int         @default(0)
  clickLogs   Click[]

  ipAddress   String?

  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime    @default(now())
}

model BulkLinks {
  id         String      @id @default(uuid())

  name       String      @default("")

  password   String?
  expiresAt  DateTime?

  links      Link[]

  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime     @default(now())
}

model Count {
  countId     String      @id @default(uuid())
  linkCount   Int         @default(0)
  qrCount     Int         @default(0)
  totalClicks Int         @default(0)
}