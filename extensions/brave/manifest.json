{
  "manifest_version": 3,
  "name": "Shortly URL Shortener",
  "version": "1.0",
  "description": "Shorten current page URL instantly",
  "permissions": ["activeTab", "tabs"],
  "host_permissions": [
    "https://shortlllyyy.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Shortly"
  }
}